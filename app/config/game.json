{
  "game_url": "https://apps.facebook.com/mobaheroes/",
  "tasks": {
    "game.quests.complete_daily_quests": {
      "interval": "1 hour",
      "after": "13:00"
    },
    "game.social.check_bonus_links": {
      "interval": "3 hours"
    },
    "game.chat.announce_bonus_links": {
      "interval": "1 hour"
    },
    "game.chat.send_chat_image": {
      "interval": "1 day",
      "at": "20:00:00"
    },
    "tasks.scheduler.check_idle": {
      "interval": "5 minutes"
    }
  }
}