{
  "active_menus": [
    "asgard",
    "titan-valley",
    "sanctuary",
    "guild-island"
  ],
  "tasks": {
    "game.guild.sanctuary.run_sanctuary": {
      "interval": "24 hours",
      "after": "11:30"
    },
    "game.guild.sanctuary.adventures.run_adventures": {
      "interval": "1 hours",
      "args": []
    },
    "play_join_adventure": {
      "interval": "45 minutes",
      "function": "game.guild.sanctuary.adventures.manager.join_or_start_adventure",
      "args": ["8", true]
    },
    "play_join_or_create_adventure": {
      "interval": "1 hours",
      "after": "19:00:00",
      "function": "game.guild.sanctuary.adventures.run_adventures",
      "args": [true]
    },
    "play_guild/titan-valley/open-artifact-spheres": {
      "after": "01:00:00",
      "interval": "24 hours",
      "function": "game.play_action",
      "args": ["guild/titan-valley/open-artifact-spheres"]
    },
    "play_guild/titan-valley/hall-of-fame-collect": {
      "interval": "24 hours",
      "function": "game.play_action",
      "args": ["guild/titan-valley/hall-of-fame-collect"]
    },
    "play_guild/titan-valley/tournament": {
      "interval": "5 hours",
      "after": "02:00",
      "function": "game.play_action",
      "args": ["guild/titan-valley/tournament"]
    },
    "play_guild/island/summon": {
      "interval": "24 hours",
      "function": "game.play_action",
      "args": ["guild/island/open-summon-spheres"]
    },
    "play_guild/island/shop": {
      "interval": "24 hours",
      "function": "game.play_action",
      "args": ["guild/island/shop"]
    },
    "play_guild/island/dungeon": {
      "interval": "10 hours",
      "function": "game.play_action",
      "args": ["guild/island/dungeon"]
    }
  }
}